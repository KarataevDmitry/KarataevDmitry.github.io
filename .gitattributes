# Normalize line endings in the repo: LF (GitHub Pages + dotnet script on Linux).
.gitattributes text eol=lf
* text=auto

*.md   text eol=lf
*.csx  text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.xml  text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.svg  text eol=lf
*.txt  text eol=lf
*.ps1  text eol=lf

# Binary / generated assets
*.pdf  -text
*.docx -text
*.png  -text
*.jpg  -text
*.jpeg -text
*.gif  -text
*.ico  -text
